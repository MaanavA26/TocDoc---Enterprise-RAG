# ═══════════════════════════════════════════════════════════════════════════════
# TocDoc – Enterprise RAG Assistant | Root .env.example
#
# This file documents every environment variable used across both services.
# Copy the relevant block into:
#   services/ingestion/.env   (for the Ingestion service)
#   services/qna/.env         (for the QnA service)
#
# All variable names are canonical UPPER_SNAKE — the exact names the code reads.
# In production, secrets marked "(Key Vault)" are loaded from Azure Key Vault at
# startup; real secrets live ONLY in Key Vault, never in this file or any .env.
# Never commit actual .env files — they are listed in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════


# ── SHARED (used by both services) ────────────────────────────────────────────

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net   # (Key Vault) in prod
AZURE_SEARCH_KEY=<set-in-key-vault>                                       # (Key Vault) in prod
INDEX_NAME=<your-index-name>                  # e.g. tocdoc-index-v1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/           # (Key Vault) in prod
AZURE_OPENAI_KEY=<set-in-key-vault>                                       # (Key Vault) in prod
AZURE_OPENAI_VERSION=2024-02-01                                           # (Key Vault) in prod
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# ── INGESTION SERVICE (services/ingestion/.env) ───────────────────────────────

# Azure Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://<your-doc-intelligence-resource>.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=<set-in-key-vault>


# ── QnA SERVICE (services/qna/.env) ──────────────────────────────────────────

# Azure OpenAI – QnA-only LLM model (chat/completion deployment).
# Endpoint/key/version are shared above. Defaults to gpt-4o-mini if unset.
AZURE_OPENAI_LLM_MODEL=gpt-4o-mini                                        # (Key Vault) in prod

# Optional L2 semantic reranking (QnA only). Empty (default) = pure hybrid
# retrieval, no behavior change. Set to the index's semantic configuration
# name (created at ingestion as `mySemanticConfig`) to enable. Requires Azure
# AI Search Standard (S1) tier or higher; on an unsupported tier retrieval
# falls back to hybrid automatically.
AZURE_SEARCH_SEMANTIC_CONFIG=

# Azure AD Service Principal (for Key Vault secret loading at startup).
# Names match Azure SDK DefaultAzureCredential conventions.
AZURE_CLIENT_ID=<your-service-principal-client-id>                        # (Key Vault) in prod
AZURE_CLIENT_SECRET=<set-in-key-vault>                                    # (Key Vault) in prod
AZURE_TENANT_ID=<your-azure-tenant-id>                                    # (Key Vault) in prod

# Azure Key Vault (vault name only, without the .vault.azure.net FQDN)
AZURE_KEY_VAULT=<your-key-vault-name>

# JWT Audience (Azure AD app registration client ID or well-known audience)
AUDIENCE_ID=<your-audience-id>


# ── RUNTIME (both services) ───────────────────────────────────────────────────

# CORS: comma-separated list of allowed origins. Empty = deny all (production default).
# Local dev example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
CORS_ALLOWED_ORIGINS=

# Uvicorn worker count (default: 2; tune based on available CPU cores)
UVICORN_WORKERS=2

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# File logging: leave empty in containers (stdout only); set to a path for local dev
LOG_FILE=
