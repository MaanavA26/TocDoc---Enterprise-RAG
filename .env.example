# ═══════════════════════════════════════════════════════════════════════════════
# TocDoc – Enterprise RAG Assistant | Root .env.example
#
# This file documents every environment variable used across both services.
# Copy the relevant block into:
#   services/ingestion/.env   (for the Ingestion service)
#   services/qna/.env         (for the QnA service)
#
# Never commit actual .env files — they are listed in .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════


# ── SHARED (used by both services) ────────────────────────────────────────────

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_KEY=<your-azure-search-admin-key>
INDEX_NAME=<your-index-name>                  # e.g. tocdoc-index-v1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# ── INGESTION SERVICE (services/ingestion/.env) ───────────────────────────────

# Azure Document Intelligence
DOC_INTELLIGENCE_ENDPOINT=https://<your-doc-intelligence-resource>.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=<your-doc-intelligence-key>


# ── QnA SERVICE (services/qna/.env) ──────────────────────────────────────────

# Azure OpenAI – QnA uses PascalCase env var names (legacy compatibility)
AzureOpenaiAccountEndpoint=https://<your-openai-resource>.openai.azure.com/
TocdocOpenAIKey=<your-azure-openai-api-key>
AzureOpenaiApiVersion=2024-02-01
AzureOpenaiLlmModel=gpt-4o-mini
AzureSearchEndpoint=https://<your-search-resource>.search.windows.net
AzureSearchKey=<your-azure-search-admin-key>

# Azure AD Service Principal (for Key Vault secret loading at startup)
TocdocSPClientID=<your-service-principal-client-id>
TocdocSPSecretValue=<your-service-principal-secret>
TocdocSPTenantID=<your-azure-tenant-id>

# Azure Key Vault
AZURE_KEY_VAULT=<your-key-vault-name>

# JWT Audience (Azure AD app registration client ID or well-known audience)
AUDIENCE_ID=<your-audience-id>


# ── RUNTIME (both services) ───────────────────────────────────────────────────

# CORS: comma-separated list of allowed origins. Empty = deny all (production default).
# Local dev example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
CORS_ALLOWED_ORIGINS=

# Uvicorn worker count (default: 2; tune based on available CPU cores)
UVICORN_WORKERS=2

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# File logging: leave empty in containers (stdout only); set to a path for local dev
LOG_FILE=
