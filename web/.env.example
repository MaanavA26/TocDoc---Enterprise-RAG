# Optional build-time defaults for local development convenience ONLY.
# Copy to `.env.local` (gitignored) and fill in. NEVER commit real values.
#
# These pre-fill the connection settings; you can also enter them in the UI,
# which persists to sessionStorage (cleared when the tab closes).

# Ingestion service ROOT URL (NOT including the /admin prefix — the client
# appends /admin automatically). Example: http://localhost:8000
VITE_ADMIN_API_BASE_URL=

# NOTE: there is intentionally NO VITE_ADMIN_TOKEN. Vite inlines every VITE_*
# var into the built client bundle, so a build-time admin token would ship in
# the JS, readable by anyone with the bundle. Enter the admin token in the UI at
# runtime instead — it is kept only in sessionStorage (cleared when the tab
# closes) and is never part of a build.
