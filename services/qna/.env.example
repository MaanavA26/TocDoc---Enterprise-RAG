# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_VERSION=2024-02-01
AZURE_OPENAI_LLM_MODEL=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Azure Cognitive Search ────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_KEY=<your-azure-search-admin-key>
INDEX_NAME=<your-index-name>

# ── Azure AD Service Principal (used for Key Vault auth) ──────────────────────
# Names match Azure SDK DefaultAzureCredential conventions, so a future switch
# from ClientSecretCredential to DefaultAzureCredential requires no rename.
AZURE_CLIENT_ID=<your-service-principal-client-id>
AZURE_CLIENT_SECRET=<your-service-principal-secret>
AZURE_TENANT_ID=<your-azure-tenant-id>

# ── Azure Key Vault ───────────────────────────────────────────────────────────
AZURE_KEY_VAULT=<your-key-vault-name>

# ── Authentication ────────────────────────────────────────────────────────────
# Audience for Azure AD JWT validation (e.g. app registration client ID).
AUDIENCE_ID=<your-app-registration-client-id-or-audience>

# ── Runtime ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000    # Comma-separated. Empty = deny all (production default)
UVICORN_WORKERS=2
LOG_LEVEL=INFO
LOG_FILE=                                     # Leave empty in containers; set to path for local file logging
